generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") 
}

model Product {
  id       Int      @id @default(autoincrement())
  name     String
  barcode  String   @unique
  price    Decimal  
  rating   Float
  category String
  brand    String   
}